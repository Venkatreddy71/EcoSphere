generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                  @id @default(uuid())
  name                  String
  email                 String                  @unique
  password              String
  role                  String                  @default("Employee")
  departmentId          String
  department            Department              @relation(fields: [departmentId], references: [id])
  xp                    Int                     @default(0)
  points                Int                     @default(0)
  badges                String[]
  avatar                String?
  status                String                  @default("Active")
  refreshToken          String?
  isDeleted             Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  complianceIssues      ComplianceIssue[]       @relation("OwnerIssues")
  reports               Report[]
  notifications         Notification[]
  csrParticipations     CSRParticipation[]
  challengeParticipations ChallengeParticipation[]
  policyAcknowledgements PolicyAcknowledgement[]
  aiConversations       AIConversation[]
  auditLogs             AuditLog[]
  documents             Document[]
}

model Department {
  id            String   @id @default(uuid())
  name          String
  code          String   @unique
  head          String
  parentId      String?
  employeeCount Int      @default(0)
  status        String   @default("Active")
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  users         User[]
  transactions  CarbonTransaction[]
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      String
  status    String   @default("Active")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmissionFactor {
  id              String   @id @default(uuid())
  category        String
  factor          Float
  unit            String
  scope           String
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  productProfiles ProductProfile[]
}

model ProductProfile {
  id             String   @id @default(uuid())
  name           String
  carbonProfile  Float
  unit           String
  factorId       String
  factor         EmissionFactor @relation(fields: [factorId], references: [id])
  description    String?
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  transactions   CarbonTransaction[]
}

model CarbonTransaction {
  id             String   @id @default(uuid())
  timestamp      DateTime @default(now())
  source         String
  departmentId   String
  department     Department @relation(fields: [departmentId], references: [id])
  productId      String?
  product        ProductProfile? @relation(fields: [productId], references: [id])
  co2e           Float
  scope          String
  transactionType String
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Goal {
  id        String   @id @default(uuid())
  title     String
  target    Float
  current   Float    @default(0)
  unit      String
  deadline  DateTime
  status    String   @default("On Track")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CSRActivity {
  id            String   @id @default(uuid())
  name          String
  description   String?
  category      String
  xp            Int      @default(0)
  pointsReward  Int      @default(0)
  date          DateTime
  status        String   @default("Active")
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  participations CSRParticipation[]
}

model CSRParticipation {
  id             String   @id @default(uuid())
  activityId     String
  activity       CSRActivity @relation(fields: [activityId], references: [id])
  employeeId     String
  employee       User       @relation(fields: [employeeId], references: [id])
  proofText      String?
  approvalStatus String   @default("Under Review")
  pointsEarned   Int      @default(0)
  completionDate DateTime?
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Challenge {
  id               String   @id @default(uuid())
  title            String
  category         String
  description      String?
  xp               Int      @default(0)
  difficulty       String   @default("Medium")
  evidenceRequired Boolean  @default(false)
  deadline         DateTime?
  status           String   @default("Active")
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  participations   ChallengeParticipation[]
}

model ChallengeParticipation {
  id             String   @id @default(uuid())
  challengeId    String
  challenge      Challenge @relation(fields: [challengeId], references: [id])
  employeeId     String
  employee       User      @relation(fields: [employeeId], references: [id])
  progress       Float    @default(0)
  proofText      String?
  approvalStatus String   @default("Active")
  xpAwarded      Int      @default(0)
  completionDate DateTime?
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Reward {
  id             String   @id @default(uuid())
  name           String
  description    String?
  pointsRequired Int
  stock          Int      @default(0)
  status         String   @default("Active")
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Badge {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String
  value       Json
  icon        String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Policy {
  id          String   @id @default(uuid())
  title       String
  content     String
  status      String   @default("Active")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  acknowledgements PolicyAcknowledgement[]
}

model PolicyAcknowledgement {
  id               String   @id @default(uuid())
  policyId         String
  policy           Policy   @relation(fields: [policyId], references: [id])
  employeeId       String
  employee         User     @relation(fields: [employeeId], references: [id])
  dateAcknowledged DateTime @default(now())
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Audit {
  id        String   @id @default(uuid())
  title     String
  auditor   String
  date      DateTime
  scope     String
  status    String   @default("Scheduled")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  issues    ComplianceIssue[]
}

model ComplianceIssue {
  id          String   @id @default(uuid())
  auditId     String
  audit       Audit    @relation(fields: [auditId], references: [id])
  severity    String
  description String
  ownerName   String
  ownerId     String?
  owner       User?    @relation("OwnerIssues", fields: [ownerId], references: [id])
  dueDate     DateTime
  status      String   @default("Open")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id          String   @id @default(uuid())
  type        String   @default("info")
  title       String
  desc        String
  time        DateTime @default(now())
  unread      Boolean  @default(true)
  recipientId String?
  recipient   User?    @relation(fields: [recipientId], references: [id])
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Report {
  id          String   @id @default(uuid())
  title       String
  type        String
  filters     Json?
  generatedBy String
  user        User     @relation(fields: [generatedBy], references: [id])
  content     Json?
  fileUrl     String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AIConversation {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  topic     String      @default("General ESG Advice")
  isDeleted Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  messages  AIMessage[]
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id])
  role           String
  content        String
  timestamp      DateTime       @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model Document {
  id            String   @id @default(uuid())
  name          String
  url           String
  type          String
  extractedData Json?
  uploadedBy    String
  user          User     @relation(fields: [uploadedBy], references: [id])
  status        String   @default("Pending")
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
