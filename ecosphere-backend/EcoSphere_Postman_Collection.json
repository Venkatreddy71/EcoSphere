{
  "info": {
    "name": "EcoSphere Enterprise API",
    "description": "Postman Collection for EcoSphere backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/dashboard/summary",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "dashboard",
                "summary"
              ]
            }
          }
        },
        {
          "name": "Get Charts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/dashboard/charts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "dashboard",
                "charts"
              ]
            }
          }
        },
        {
          "name": "Get KPIs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/dashboard/kpis",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "dashboard",
                "kpis"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "AI Recommendation Engine",
      "item": [
        {
          "name": "Get Recommendation",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/ai/recommend",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "ai",
                "recommend"
              ]
            }
          }
        },
        {
          "name": "Get Risk Analysis",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/ai/risk",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "ai",
                "risk"
              ]
            }
          }
        },
        {
          "name": "Get Forecast",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/ai/forecast",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "ai",
                "forecast"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Document AI",
      "item": [
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "document",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/documents/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "documents",
                "upload"
              ]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ]
}
